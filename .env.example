# Server port
PORT=3000

# Moderator dashboard password
MOD_PASSWORD=changeme

# Slideshow interval in milliseconds
SLIDE_INTERVAL=7000

# Max upload file size in bytes (default 10 MB)
MAX_UPLOAD_BYTES=10485760

# Public base URL shown in QR code (e.g. http://192.168.1.50:3000)
# Leave blank to auto-detect from request host
PUBLIC_URL=
